generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  role       String   @default("USER")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  usedCodeId String?
  accounts      Account[]
  referralCodes ReferralCode[] @relation("CodeCreator")
  @@map("users")
}

model Account {
  id          String    @id @default(cuid())
  username    String    @unique
  fullName    String?
  avatar      String?
  bio         String?
  followers   Int       @default(0)
  following   Int       @default(0)
  posts       Int       @default(0)
  isTracked   Boolean   @default(true)
  isPrivate   Boolean   @default(false)
  isVerified  Boolean   @default(false)
  status      String    @default("ACTIVE")
  lastChecked DateTime?
  lastPostId          String?
  lastPostTime        DateTime?
  lastStoryId         String?
  lastStoryTime       DateTime?
  lastActivityTime    DateTime?
  activeStoryIds      String?
  followersAtLastSync Int @default(0)
  notifyOnFollow    Boolean?
  notifyOnUnfollow  Boolean?
  notifyOnNewPost   Boolean?
  notifyOnNewStory  Boolean?
  notifyOnBioChange Boolean?
  // حقول المراقبة المتطورة
  lastPostDetectedAt      DateTime?
  lastReelDetectedAt      DateTime?
  lastBioChangeAt         DateTime?
  lastPpChangeAt          DateTime?
  lastVisibilityChangeAt  DateTime?
  bioHistory              Json?
  ppHistory               Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities      Activity[]
  snapshots       FollowerSnapshot[]
  stories         Story[]
  comments        Comment[]
  followerChanges FollowerChange[]
  @@map("accounts")
}

model Story {
  id         String   @id
  imageUrl   String?
  videoUrl   String?
  expiresAt  DateTime
  notified   Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  accountId  String
  account    Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@map("stories")
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  data      Json?
  createdAt DateTime @default(now())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@map("activities")
}

model FollowerSnapshot {
  id         String   @id @default(cuid())
  followers  Int
  following  Int
  posts      Int
  recordedAt DateTime @default(now())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@map("follower_snapshots")
}

model FollowerChange {
  id         String   @id @default(cuid())
  oldCount   Int
  newCount   Int
  change     Int
  recordedAt DateTime @default(now())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@map("follower_changes")
}

model Comment {
  id          String   @id @default(cuid())
  commentId   String   @unique
  mediaId     String
  text        String
  timestamp   DateTime
  mediaOwner  String?
  createdAt   DateTime @default(now())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@map("comments")
}

model ReferralCode {
  id              String    @id @default(cuid())
  code            String    @unique
  label           String?
  isUsed          Boolean   @default(false)
  maxUses         Int       @default(1)
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  allowedAccounts String?
  createdAt       DateTime  @default(now())
  creatorId       String
  creator         User   @relation("CodeCreator", fields: [creatorId], references: [id])
  @@map("referral_codes")
}

model Settings {
  id                String   @id @default(cuid())
  telegramBotToken  String?
  telegramChatId    String?
  apifyApiToken     String?
  webhookUrl        String?
  webhookEnabled    Boolean  @default(false)
  notifyOnFollow    Boolean  @default(true)
  notifyOnUnfollow  Boolean  @default(true)
  notifyOnNewPost   Boolean  @default(true)
  notifyOnNewStory  Boolean  @default(true)
  notifyOnBioChange Boolean  @default(false)
  notifyOnPrivate   Boolean  @default(true)
  checkIntervalMins Int      @default(30)
  updatedAt         DateTime @updatedAt
  @@map("settings")
}
