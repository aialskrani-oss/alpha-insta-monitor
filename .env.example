# قاعدة البيانات - Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# NextAuth - مفتاح سري عشوائي (32 حرف على الأقل)
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="https://your-domain.vercel.app"

# بيانات المشرف الرئيسي
ADMIN_EMAIL="admin@alphamonitor.com"
ADMIN_PASSWORD="YourSecurePassword123!"
ADMIN_NAME="Alpha Admin"

# مفتاح حماية Cron - أي نص عشوائي آمن
CRON_SECRET="your-random-cron-secret-key"

# توكن بوت تيليجرام (اختياري - يُضبط من داخل لوحة التحكم)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
